generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String          @id @db.Uuid
  fullName    String          @map("full_name")
  email       String          @unique
  role        String
  avatarUrl   String?         @map("avatar_url")
  phone       String?
  isActive    Boolean         @default(true) @map("is_active")
  lastLoginAt DateTime?       @map("last_login_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")

  createdBroadcasts Broadcast[] @relation("broadcast_created_by")
  auditLogs         AuditLog[]
  eventActions      EventAction[]
  broadcastRecipients BroadcastRecipient[]

  @@map("profiles")
}

model Building {
  id         String     @id @default(uuid()) @db.Uuid
  name       String
  code       String     @unique
  address    String?
  timezone   String     @default("UTC")
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @default(now()) @updatedAt @map("updated_at")

  floors     Floor[]
  zones      Zone[]
  events     Event[]
  broadcasts Broadcast[]
  auditLogs  AuditLog[]
  routes     Route[]

  @@map("buildings")
}

model Floor {
  id         String   @id @default(uuid()) @db.Uuid
  buildingId String   @map("building_id") @db.Uuid
  name       String
  level      Int
  planUrl    String?  @map("plan_url")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  zones      Zone[]
  events     Event[]

  @@unique([buildingId, level])
  @@map("floors")
}

model Zone {
  id          String   @id @default(uuid()) @db.Uuid
  buildingId  String   @map("building_id") @db.Uuid
  floorId     String?  @map("floor_id") @db.Uuid
  name        String
  zoneType    String   @default("general") @map("zone_type")
  status      String   @default("safe")
  geo         Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  building    Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor       Floor?   @relation(fields: [floorId], references: [id], onDelete: SetNull)
  events      Event[]
  routesFrom  Route[]  @relation("route_from_zone")
  routesTo    Route[]  @relation("route_to_zone")

  @@index([buildingId])
  @@index([floorId])
  @@map("zones")
}

model Event {
  id          String       @id @default(uuid()) @db.Uuid
  buildingId  String       @map("building_id") @db.Uuid
  floorId     String?      @map("floor_id") @db.Uuid
  zoneId      String?      @map("zone_id") @db.Uuid
  eventType   String       @map("event_type")
  severity    String
  status      String       @default("active")
  title       String
  description String?
  source      String       @default("ai_model")
  metadata    Json         @default("{}")
  detectedAt  DateTime     @default(now()) @map("detected_at")
  resolvedAt  DateTime?    @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at")

  building    Building     @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor       Floor?       @relation(fields: [floorId], references: [id], onDelete: SetNull)
  zone        Zone?        @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  actions     EventAction[]
  modelEvents ModelEvent[]
  routes      Route[]

  @@index([buildingId, status])
  @@index([detectedAt])
  @@map("events")
}

model EventAction {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  action    String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actor     Profile? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@map("event_actions")
}

model Broadcast {
  id            String                @id @default(uuid()) @db.Uuid
  buildingId    String                @map("building_id") @db.Uuid
  createdById   String?               @map("created_by") @db.Uuid
  audienceType  String                @map("audience_type")
  audienceValue String?               @map("audience_value")
  message       String
  deliveryMode  String                @default("sms") @map("delivery_mode")
  priority      String                @default("normal")
  status        String                @default("queued")
  recipientCount Int                  @default(0) @map("recipient_count")
  successCount  Int                   @default(0) @map("success_count")
  failedCount   Int                   @default(0) @map("failed_count")
  createdAt     DateTime              @default(now()) @map("created_at")
  sentAt        DateTime?             @map("sent_at")
  updatedAt     DateTime              @default(now()) @updatedAt @map("updated_at")

  building      Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  createdBy     Profile?              @relation("broadcast_created_by", fields: [createdById], references: [id], onDelete: SetNull)
  recipients    BroadcastRecipient[]

  @@index([buildingId, createdAt(sort: Desc)])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id                String   @id @default(uuid()) @db.Uuid
  broadcastId       String   @map("broadcast_id") @db.Uuid
  profileId         String?  @map("profile_id") @db.Uuid
  phone             String?
  status            String   @default("queued")
  providerMessageId String?  @map("provider_message_id")
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  broadcast         Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  profile           Profile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([broadcastId])
  @@map("broadcast_recipients")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  buildingId  String?  @map("building_id") @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id") @db.Uuid
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  building    Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  actor       Profile?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([buildingId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model ModelEvent {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String?  @map("event_id") @db.Uuid
  modelType  String   @map("model_type")
  prediction String
  confidence Decimal  @db.Decimal(5, 4)
  frameUri   String?  @map("frame_uri")
  frameIndex Int?     @map("frame_index")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  event      Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("model_events")
}

model Route {
  id             String   @id @default(uuid()) @db.Uuid
  eventId        String?  @map("event_id") @db.Uuid
  buildingId     String   @map("building_id") @db.Uuid
  fromZoneId     String?  @map("from_zone_id") @db.Uuid
  toZoneId       String?  @map("to_zone_id") @db.Uuid
  routeType      String   @default("evacuation") @map("route_type")
  path           Json
  safetyScore    Decimal  @default(0) @db.Decimal(5, 4) @map("safety_score")
  distanceMeters Decimal? @map("distance_meters") @db.Decimal(10, 2)
  etaSeconds     Int?     @map("eta_seconds")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  event          Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  building       Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  fromZone       Zone?    @relation("route_from_zone", fields: [fromZoneId], references: [id], onDelete: SetNull)
  toZone         Zone?    @relation("route_to_zone", fields: [toZoneId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([buildingId, status])
  @@map("routes")
}
